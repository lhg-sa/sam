 "html": "<style>\n\t@page { size: Letter; margin: 0.4in; }\n\tbody, html { margin: 0; padding: 0; height: 100%; }\n\t.print-format { font-family: \"OCR-A\", \"OCR-B\", \"Courier New\", monospace; font-size: 10pt; margin: 0; padding: 0; }\n\t.page { position: relative; min-height: 10in; box-sizing: border-box; page-break-after: avoid; page-break-inside: avoid; }\n\t.footer { position: absolute; left: 0; right: 0; bottom: 1.25in; }\n\t.center { text-align: center; }\n\t.right { text-align: right; }\n\t.nowrap { white-space: nowrap; }\n\t.indent { display: inline-block; margin-left: 40ch; }\n\t.items-table { width: 100%; border-collapse: collapse; font-size: 8pt; margin-left: -25ch; }\n\t.items-table td { padding: 0; }\n\t.spacer-1 { height: 0.75em; }\n\t.spacer-2 { height: 1.5em; }\n\t.spacer-3 { height: 2.25em; }\n\t.spacer-4 { height: 3em; }\n\t.spacer-5 { height: 3.75em; }\n\t.spacer-10 { height: 7.5em; }\n</style>\n\n{% set day = frappe.utils.formatdate(doc.transaction_date, \"dd\") if doc.transaction_date else \"\" %}\n{% set month = frappe.utils.formatdate(doc.transaction_date, \"MM\") if doc.transaction_date else \"\" %}\n{% set year = frappe.utils.formatdate(doc.transaction_date, \"YYYY\") if doc.transaction_date else \"\" %}\n\n<div class=\"print-format\">\n\t<div class=\"page\">\n\t\t<!-- Encabezado: Nombre del documento -->\n\t\t<div class=\"spacer-5\"></div>\n\t\t<table style=\"width:100%; border-collapse: collapse;\">\n\t\t\t<tr>\n\t\t\t\t<td class=\"center nowrap\" style=\"font-size:8pt;\">{{ doc.name }}</td>\n\t\t\t</tr>\n\t\t</table>\n\t\t\n\t\t<div class=\"spacer-10\"></div>\n\n\t\t<!-- Fila: Fecha | Unidad | Campo 9 -->\n\t\t<table style=\"width:100%; border-collapse: collapse;\">\n\t\t\t<tr>\n\t\t\t\t<!-- Fecha: d\u00eda, mes, a\u00f1o -->\n\t\t\t\t<td style=\"width:22%; vertical-align: top;\" class=\"center\">{{ day }} {{ month }} {{ year }}</td>\n\t\t\t\t\n\t\t\t\t<!-- Unidad -->\n\t\t\t\t<td style=\"width:48%; vertical-align: top;\" class=\"center\">\n\t\t\t\t\t<div class=\"spacer-3\"></div>\n\t\t\t\t\t{{ (doc.campo_5 or \"-\") ~ \"-\" }} {{ doc.custom_unidad }}\n\t\t\t\t</td>\n\t\t\t\t\n\t\t\t\t<!-- Campo 9 -->\n\t\t\t\t<td style=\"width:30%; vertical-align: top;\" class=\"center\">\n\t\t\t\t\t<div class=\"spacer-4\"></div>\n\t\t\t\t\t&nbsp;&nbsp;&nbsp;&nbsp;{{ (doc.campo_9 or \"-\") ~ \"-\" }}\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t</table>\n\n\t\t<!-- Fila: Campos 7 y 8 -->\n\t\t<table style=\"width:100%; border-collapse: collapse;\">\n\t\t\t<tr>\n\t\t\t\t<td style=\"width:70%;\" class=\"center\">{{ (doc.campo_7 or \"-\") ~ \"-\" }} {{ (doc.campo_8 or \"-\") ~ \"-\" }}</td>\n\t\t\t\t<td style=\"width:30%;\"></td>\n\t\t\t</tr>\n\t\t</table>\n\n\t\t<div class=\"spacer-4\"></div>\n\n\t\t<!-- Tipo: BIENES | MATERIALES | SUMINISTROS | SERVICIOS -->\n\t\t<table style=\"width:100%; border-collapse: collapse;\">\n\t\t\t<tr class=\"center\">\n\t\t\t\t<td style=\"width:25%;\"><span class=\"indent\">&nbsp;&nbsp;&nbsp;&nbsp;{% if doc.custom_tipo == \"BIENES\" %}X{% endif %}</span></td>\n\t\t\t\t<td style=\"width:25%;\"><span class=\"indent\">&nbsp;&nbsp;&nbsp;&nbsp;{% if doc.custom_tipo == \"MATERIALES\" %}X{% endif %}</span></td>\n\t\t\t\t<td style=\"width:25%;\"><span class=\"indent\">&nbsp;&nbsp;&nbsp;&nbsp;{% if doc.custom_tipo == \"SUMINISTROS\" %}X{% endif %}</span></td>\n\t\t\t\t<td style=\"width:25%;\"><span class=\"indent\">&nbsp;&nbsp;&nbsp;&nbsp;{% if doc.custom_tipo == \"SERVICIOS\" %}X{% endif %}</span></td>\n\t\t\t</tr>\n\t\t</table>\n\n\t\t<div class=\"spacer-3\"></div>\n\n\t\t<!-- Tabla de Items -->\n\t\t<table class=\"items-table\">\n\t\t\t{% for item in doc.items %}\n\t\t\t<tr class=\"center\">\n\t\t\t\t<td style=\"width:12.5%; text-align: left; padding-left: 7ch;\">{{ item.item_code or \"-\" }}</td>\n\t\t\t\t<td style=\"width:8%; text-align: left; margin-left: -6ch;\">{{ frappe.db.get_value(\"Item\", item.item_code, \"custom_renglon\") or \"-\" }}</td>\n\t\t\t\t<td style=\"width:10%; position: relative; left: -5ch;\">{{ item.qty or \"-\" }}</td>\n\t\t\t\t<td style=\"width:35.5%; text-align: left; margin-left: -7ch;\">{{ item.item_name or \"-\" }}</td>\t\t\t\t\n\t\t\t\t<td style=\"width:10%; text-align: left; margin-left: -30ch;\">{{ item.uom or \"-\" }}</td>\n\t\t\t\t<td style=\"width:10%; text-align: left; margin-left: -25ch;\">{{ item.campo_23 or \"-\" }}</td>\n\t\t\t\t<td style=\"width:7%;  text-align: left; margin-left: -25ch;\">{{ item.campo_19 or \"-\" }}</td>\n\t\t\t\t<td style=\"width:7%;\">{{ item.campo_20 or \"-\" }}</td>\n\t\t\t</tr>\n\t\t\t{% endfor %}\n\t\t</table>\n\n\t\t<!-- Footer -->\n\t\t<div class=\"footer\">\n\t\t\t<table style=\"width:100%; border-collapse: collapse;\">\n\t\t\t\t<tr>\n\t\t\t\t\t<td colspan=\"6\"></td>\n\t\t\t\t\t<td class=\"right nowrap\">{{ (doc.campo_21 or \"-\") ~ \"-\" }}</td>\n\t\t\t\t</tr>\n\t\t\t</table>\n\n\t\t\t<table style=\"width:100%; border-collapse: collapse;\">\n\t\t\t\t<tr>\n\t\t\t\t\t<td style=\"width:100%;\">{{ (doc.campo_22 or \"-\") ~ \"-\" }}</td>\n\t\t\t\t</tr>\n\t\t\t</table>\n\t\t</div>\n\t</div>\n</div>\n",
 "idx": 0,
